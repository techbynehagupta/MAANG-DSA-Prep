{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch empty JS → template.md",
      "type": "shell",
      "command": "python3",
      "args": [".cursor/hooks/apply_js_template.py", "--watch"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "watch-empty-js",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^apply_js_template: watching",
          "endsPattern": "^__watch_empty_js_never__$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
